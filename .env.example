# Server Configuration
PORT=3001

# PostgreSQL Configuration
# Fill this in .env with the writable backend database user.
DATABASE_URL=postgresql://study_agent_dev:your_password@localhost:5432/study_agent_db
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000

# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Doubao API Configuration (字节跳动豆包)
ARK_API_KEY=your_doubao_api_key_here
ARK_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_MODEL=doubao-seed-2-0-lite-260215

# CORS Configuration (optional)
# CORS_ORIGIN=http://localhost:5173
