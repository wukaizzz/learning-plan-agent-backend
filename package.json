{
  "name": "react-project-backend",
  "version": "1.0.0",
  "description": "Backend server for React Agent Chat",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --exec \"node --import dotenv/config\" src/index.js",
    "start": "cross-env NODE_ENV=production node --import dotenv/config src/index.js",
    "dev:watch": "cross-env NODE_ENV=development node --watch --import dotenv/config src/index.js",
    "db:health": "node --import dotenv/config scripts/db/health-check.js",
    "db:migrate": "node --import dotenv/config scripts/db/migrate.js",
    "db:seed": "node --import dotenv/config scripts/db/seed-dev.js",
    "test:persistence": "node --import dotenv/config scripts/api-test/plan-persistence-smoke.js",
    "test:persistence:space-chat": "node --import dotenv/config scripts/api-test/space-chat-persistence-smoke.js",
    "test": "node --test",
    "commit": "git-cz"
  },
  "keywords": [
    "chat",
    "agent",
    "deepseek"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^1.1.47",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/langgraph-checkpoint-postgres": "1.0.1",
    "@langchain/openai": "^1.4.6",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cz-git": "^1.13.1",
    "nodemon": "^3.1.3",
    "pino-pretty": "^13.1.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  }
}
